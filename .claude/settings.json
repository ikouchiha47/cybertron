{
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 tools/code_memory.py",
            "timeout": 8
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 tools/code_memory.py",
            "timeout": 12
          }
        ]
      }
    ]
  }
}
